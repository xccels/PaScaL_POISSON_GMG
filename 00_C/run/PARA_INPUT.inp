# meshes
nx 256
ny 256
nz 256

# origin
ox -0.5
oy -0.5
oz -0.5

# length
lx 2.0
ly 2.0
lz 2.0

# mesh_stretch
ax 1.0
ay 1.0
az 1.0

# procs
npx 2
npy 1
npz 1

# control
maxiteration 10
tolerance 1.0e-11
number_of_vcycles 100
number_of_levels 8
aggregation_method 2
aggregation_level 0
omega_sor 1.6

# coefficients
alpha_x 1.0
alpha_y 1.0
alpha_z 1.0
